{
  "expo": {
    "name": "Aufgaben",
    "slug": "aufgaben",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./icon.png",
    "platforms": ["android"],
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./icon.png",
          "color": "#ffffff"
        }
      ]
    ],
    "android": {
      "package": "com.aufgaben.app",
      "adaptiveIcon": {
        "foregroundImage": "./icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "ios": {
      "bundleIdentifier": "com.aufgaben.app"
    },
    "splash": {
      "backgroundColor": "#ffffff",
      "resizeMode": "contain",
      "image": "./assets/splash.png"
    }
  }
}
